# ─────────────────────────────────────────────────────────────
# HidenHost WebSocket relay — environment
# Copy to .env on the box (vicky.hidencloud.com) and edit values.
#
# This server is a PURE relay. It does not talk to Supabase.
# The Lovable frontend handles all database/auth work directly.
# ─────────────────────────────────────────────────────────────

# Bind address / port. On hidencloud the public TCP port is 24609.
HOST=0.0.0.0
PORT=24609

# Public URL clients (Lovable frontend + Rust agents) connect to.
# Reverse proxy: https://veltrix.hidenfree.com -> vicky.hidencloud.com:24609
PUBLIC_WS_URL=wss://veltrix.hidenfree.com
PUBLIC_HTTP_URL=https://veltrix.hidenfree.com

# Shared secret — agents and frontend must send this in the
# `x-hiden-key` header (or ?key=... query string) to connect.
HIDEN_AUTH_KEY=replace-me-with-a-long-random-string

# Heartbeat / housekeeping
PING_INTERVAL_MS=25000
DEAD_TIMEOUT_MS=60000

# CORS — comma separated list, or * for everything
CORS_ORIGINS=*
