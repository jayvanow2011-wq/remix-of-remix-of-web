# ─────────────────────────────────────────────────────────────
# Python WebSocket relay — environment
# Same protocol as hidenhost/server.js (Node), drop-in replacement.
# ─────────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=24609

# Public URL clients connect to (behind reverse proxy)
PUBLIC_WS_URL=wss://veltrix.hidenfree.com
PUBLIC_HTTP_URL=https://veltrix.hidenfree.com

# Shared auth key — agents and frontend send via x-hiden-key header or ?key= param
HIDEN_AUTH_KEY=replace-me-with-a-long-random-string

# Heartbeat / housekeeping
PING_INTERVAL_SEC=25
DEAD_TIMEOUT_SEC=60

# CORS origins — comma separated, or * for everything
CORS_ORIGINS=*
