# ─────────────────────────────────────────────────────────────
# LunesHost WebSocket relay — node70.lunes.host:3242
# ─────────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=3242

# Public URL — no domain, just raw ip:port
PUBLIC_WS_URL=ws://node70.lunes.host:3242
PUBLIC_HTTP_URL=http://node70.lunes.host:3242

# Shared secret — agents and frontend must send this to connect
HIDEN_AUTH_KEY=ilovenrattingppl

# Heartbeat / housekeeping
PING_INTERVAL_MS=25000
DEAD_TIMEOUT_MS=60000

# CORS — allow all
CORS_ORIGINS=*
